TELEGRAM_BOT_TOKEN=123456789:replace_with_token_from_BotFather

# Start with this blank. Message the bot once, copy the chat id it replies with,
# then place it here and restart the bridge.
TELEGRAM_ALLOWED_CHAT_IDS=

# Optional side-channel used by the current Codex chat without spawning a
# separate Codex process. Use a separate bot token if the main bridge is also
# polling getUpdates, otherwise replies can race between the two pollers.
TELEGRAM_SIDECHANNEL_BOT_TOKEN=
TELEGRAM_SIDECHANNEL_CHAT_IDS=
TELEGRAM_SIDECHANNEL_DEFAULT_CHAT_ID=

# Optional localhost notifier service. This lets Codex talk only to localhost
# while the service handles Telegram network calls.
TELEGRAM_NOTIFIER_HOST=127.0.0.1
TELEGRAM_NOTIFIER_PORT=8787
TELEGRAM_NOTIFIER_BOT_TOKEN=
TELEGRAM_NOTIFIER_CHAT_ID=
TELEGRAM_NOTIFIER_ALLOWED_CHAT_IDS=
TELEGRAM_NOTIFIER_LONG_POLL_TIMEOUT_SECONDS=30

# Optional voice-message transcription. Local command receives the downloaded
# Telegram audio path and must print transcript text to stdout.
TELEGRAM_VOICE_TRANSCRIBE_COMMAND=
TELEGRAM_LOCAL_WHISPER_MODEL=base
TELEGRAM_LOCAL_WHISPER_LANGUAGE=

# Optional OpenAI transcription backend. Set the model explicitly when using it.
OPENAI_API_KEY=
TELEGRAM_VOICE_TRANSCRIBE_MODEL=
TELEGRAM_VOICE_TRANSCRIBE_URL=https://api.openai.com/v1/audio/transcriptions

# Optional instant-ish Telegram gateway. The default delivery mode posts
# incoming Telegram messages into the running Codex Desktop active chat.
# Fallback resume mode targets the configured Codex thread when the app-server
# route is unavailable.
TELEGRAM_GATEWAY_POLL_INTERVAL_SECONDS=1
TELEGRAM_GATEWAY_CODEX_THREAD_ID=
TELEGRAM_GATEWAY_CODEX_CWD=
TELEGRAM_GATEWAY_CODEX_TIMEOUT_SECONDS=900
TELEGRAM_GATEWAY_CODEX_FULL_AUTO=true
TELEGRAM_GATEWAY_CODEX_HOME=
TELEGRAM_GATEWAY_DELIVERY_MODE=active-app
TELEGRAM_GATEWAY_FALLBACK_TO_RESUME=true
TELEGRAM_GATEWAY_LOCK_MAX_AGE_SECONDS=900
TELEGRAM_GATEWAY_LOCK_WAIT_SECONDS=1800
TELEGRAM_NOTIFIER_INTERACTIVE_CODEX=true
TELEGRAM_NOTIFIER_INTERACTIVE_NO_ACK=true

# Codex settings. This is the current "Connect phone via Telegram" thread.
CODEX_THREAD_ID=019dc13c-a896-7b02-bc06-97ecdc52bc9d
CODEX_CWD=C:\Users\barru\Documents\New project
CODEX_PATH=codex

# Lets Codex do normal workspace tasks without pausing for desktop approvals.
# Keep this false if you want a more restrictive first test.
CODEX_FULL_AUTO=true
CODEX_TASK_TIMEOUT_SECONDS=900

# Optional interactive desktop broker. Start run_broker.ps1 in your visible Windows session.
DESKTOP_BROKER_URL=http://127.0.0.1:8765
DESKTOP_BROKER_TOKEN=

# Desktop agent performance tuning.
# fast: fewer automatic post-action checks, better speed for normal desktop work
# safe: more conservative behavior for troubleshooting or fragile flows
DESKTOP_AGENT_MODE=fast
DESKTOP_AGENT_DRAG_STEPS=8
DESKTOP_AGENT_DRAG_DURATION_MS=240
DESKTOP_AGENT_FOCUS_RESTORE_DELAY_MS=60
DESKTOP_AGENT_FOCUS_RETRY_DELAY_MS=25

# Fast active-window preview cache for lighter-weight desktop vision.
DESKTOP_AGENT_PREVIEW_INTERVAL_MS=300
DESKTOP_AGENT_PREVIEW_IDLE_INTERVAL_MS=1200
DESKTOP_AGENT_PREVIEW_ACTIVE_FOR_MS=5000
DESKTOP_AGENT_PREVIEW_SOURCE=active_monitor
DESKTOP_AGENT_PREVIEW_MAX_WIDTH=480
DESKTOP_AGENT_PREVIEW_MAX_HEIGHT=300
DESKTOP_AGENT_PREVIEW_PERSIST_TO_DISK=false
